{
  "$schema": "https://raw.githubusercontent.com/nicovrc/tauri-docs/v2/references/config.schema.json",
  "productName": "NihongoMaster",
  "version": "0.1.0",
  "identifier": "com.nihongomaster.app",
  "build": {
    "beforeDevCommand": "lsof -ti:1420 | xargs kill -9 2>/dev/null; npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NihongoMaster - Japanese Learning",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {}
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:nihongo-master.db"
      ]
    }
  }
}

{
  "name": "nihongo-master",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "lsof -ti:1420 | xargs kill -9 2>/dev/null; true && tauri dev",
    "kill-port": "lsof -ti:1420 | xargs kill -9 2>/dev/null; echo 'Port 1420 cleared'",
    "generate-audio": "npx tsx scripts/generate-audio.ts",
    "generate-audio:kana": "npx tsx scripts/generate-audio.ts --type=kana",
    "generate-audio:vocab": "npx tsx scripts/generate-audio.ts --type=vocab",
    "generate-audio:kanji": "npx tsx scripts/generate-audio.ts --type=kanji",
    "generate-audio:slow": "npx tsx scripts/generate-audio.ts --slow",
    "tauri:build": "tauri build",
    "tauri:build:dmg": "tauri build --bundles dmg",
    "tauri:build:app": "tauri build --bundles app"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-sql": "^2.2.0",
    "framer-motion": "^12.6.3",
    "i18next": "^25.0.1",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.1",
    "react-router-dom": "^7.5.0",
    "recharts": "^2.15.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@tailwindcss/vite": "^4.1.3",
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.1"
  }
}
